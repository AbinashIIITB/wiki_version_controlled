{
    "compilerOptions": {
          "target": "ES2020",
          "module": "commonjs",
          "rootDir": "./src",
          "outDir": "./dist",
          "strict": true,
          "esModuleInterop": true,
          "skipLibCheck": true,
          "forceConsistentCasingInFileNames": true,
          "baseUrl": "./src",
          "ignoreDeprecations": "6.0",
          "paths": {
                  "*": ["node_modules/*"]
          }
    },
    "include": ["src/**/*"],
    "exclude": ["node_modules", "**/*.spec.ts"]
}
